{
  "version": 2,
  "env": {
    "ENABLE_UV": "0",
    "VERCEL_FORCE_NO_BUILD_CACHE": "1",
    "PYTHON_VERSION": "3.12"
  },
  "builds": [
    {
      "src": "mystarlinkstats/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "mystarlinkstats/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "mystarlinkstats/wsgi.py"
    }
  ]
}
